      <aliases enabled='yes' />
      <column caption='ROI' datatype='real' name='[Calculation_1049243579584512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [budget] &gt; 0 THEN&#13;&#10;    ([revenue] - [budget]) / [budget]&#13;&#10;END' />
      </column>
      <column caption='Avg Budget' datatype='real' name='[Calculation_1049243610734595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG([budget]) }' />
      </column>
      <column caption='Avg Revenue' datatype='real' name='[Calculation_1049243610906628]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG([revenue]) }' />
      </column>
      <column caption='Budget–Revenue Quadrant' datatype='string' name='[Calculation_1049243611095045]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [budget] &lt; [Calculation_1049243610734595] AND [revenue] &lt; [Calculation_1049243610906628] THEN&#13;&#10;    &quot;Low Budget – Low Revenue&quot;&#13;&#10;ELSEIF [budget] &lt; [Calculation_1049243610734595] AND [revenue] &gt;= [Calculation_1049243610906628] THEN&#13;&#10;    &quot;Low Budget – High Revenue&quot;&#13;&#10;ELSEIF [budget] &gt;= [Calculation_1049243610734595] AND [revenue] &lt; [Calculation_1049243610906628] THEN&#13;&#10;    &quot;High Budget – Low Revenue&quot;&#13;&#10;ELSE&#13;&#10;    &quot;High Budget – High Revenue&quot;&#13;&#10;END' />
      </column>
      <column caption='Top Bottom Filter' datatype='boolean' name='[Calculation_1049243623804934]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &quot;Top 5&quot; THEN&#13;&#10;    RANK_DENSE(AVG([Calculation_1049243630383112]), &apos;desc&apos;) &lt;= 5&#13;&#10;ELSE&#13;&#10;    RANK_DENSE(AVG([Calculation_1049243630383112]), &apos;asc&apos;) &lt;= 5&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Selected Metric' datatype='real' name='[Calculation_1049243627900935]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Rating&quot; THEN AVG([rating])&#13;&#10;ELSE AVG([popularity])&#13;&#10;END' />
      </column>
      <column caption='Metric per Title' datatype='real' name='[Calculation_1049243630383112]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Rating&quot; THEN&#13;&#10;    { FIXED [title] : AVG([rating]) }&#13;&#10;ELSE&#13;&#10;    { FIXED [title] : AVG([popularity]) }&#13;&#10;END' />
      </column>
      <column caption='Freeze Panes' datatype='table' name='[__tableau_internal_object_id__].[Freeze Panes_BFA22DEA7F3C4CA3B6B8D9CD40016266]' role='measure' type='quantitative' />
      <column caption='Budget' datatype='integer' default-format='n#,##0,,M;-#,##0,,M' name='[budget]' role='measure' type='quantitative' />
      <column caption='Cast' datatype='string' name='[cast]' role='dimension' type='nominal' />
      <column caption='Country' datatype='string' name='[country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
